# KrishiVani Environment Variables
# Copy this file to .env and fill in your values

# Flask Config
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=True

# Database
DATABASE_URL=sqlite:///krishivani.db
# For PostgreSQL: postgresql://user:password@localhost/krishivani

# JWT Config
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRES=86400   # in seconds (86400 = 24 hours)
# NOTE: This value is internally converted to timedelta(seconds=...) in app/__init__.py

# ========================================
# FREE API KEYS - Yahan apni keys daalo
# ========================================

# GROQ - Chat + Voice Transcription (FREE)
# Key kahan se lein: https://console.groq.com
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# GOOGLE GEMINI - Crop Image Analysis (FREE)
# Key kahan se lein: https://aistudio.google.com
# IMPORTANT: Gemini key 'AIza...' se start hoti hai, OpenAI key 'sk-proj-' se nahi!
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Upload Config
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads/crops
ALLOWED_EXTENSIONS=png,jpg,jpeg,webp

# Weather API (already working - free)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
